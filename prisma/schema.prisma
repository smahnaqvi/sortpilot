// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SortingRule {
  id             Int      @id @default(autoincrement())
  shop           String
  name           String
  rule           String
  collectionIds  String
  schedule       String   @default("manual")
  isActive       Boolean  @default(true)
  pushOutOfStockDown Boolean  @default(true)

  lastRunAt      DateTime?
  nextRunAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  executionLogs  RuleExecutionLog[]

  @@index([shop])
  @@index([shop, rule])
  @@unique([shop, name])
}

model RuleExecutionLog {
  id             Int      @id @default(autoincrement())

  sortingRuleId  Int
  sortingRule    SortingRule @relation(fields: [sortingRuleId], references: [id], onDelete: Cascade)

  status         String
  message        String

  startedAt      DateTime @default(now())
  completedAt    DateTime?

  createdAt      DateTime @default(now())

  @@index([sortingRuleId])
}

model CollectionSetting {
  id           Int      @id @default(autoincrement())
  shop         String
  collectionId String
  isEnabled    Boolean  @default(false)
  rule          String   @default("inventory_high_low")
  pushOutOfStockDown Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, collectionId])
  @@index([shop])
}
